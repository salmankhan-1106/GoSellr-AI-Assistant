# Groq (AI assistant chatbot) — OpenAI-compatible chat completions API
# Get a free key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
GROQ_API_URL=https://api.groq.com/openai/v1/chat/completions
GROQ_MODEL=llama-3.1-8b-instant

# Max chatbot messages per user/guest per day
AI_CHAT_DAILY_LIMIT=50

# Your host app's Postgres connection (Prisma) — not used directly by this
# module, but PrismaService needs it at boot.
DATABASE_URL=postgresql://user:password@localhost:5432/your_db
